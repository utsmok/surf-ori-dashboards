<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ORI Dashboards | Interactive dashboards on research in the Netherlands</title>
  <!-- Include Tailwind CSS via CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="icon" href="https://www.surf.nl/themes/surf/favicons/favicon.ico" />
  <link rel="mask-icon" href="https://www.surf.nl/themes/surf/favicons/safari-pinned-tab.svg" />
  <link rel="icon" sizes="16x16" href="https://www.surf.nl/themes/surf/favicons/favicon-16x16.png" />
  <link rel="icon" sizes="32x32" href="https://www.surf.nl/themes/surf/favicons/favicon-32x32.png" />
  <link rel="icon" sizes="192x192" href="https://www.surf.nl/themes/surf/favicons/android-chrome-192x192.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="https://www.surf.nl/themes/surf/favicons/apple-touch-icon.png" />
  <link rel="manifest" href="https://www.surf.nl/themes/surf/favicons/site.webmanifest" crossorigin="use-credentials" />
  <meta name="msapplication-config" content="https://www.surf.nl/themes/surf/favicons/browserconfig.xml" />
</head>
<body class="font-sans text-gray-800 bg-white p-5">    
  <div class="max-w-4xl mx-auto">
    <!-- Header -->
    <header class="bg-gray-100 p-6 text-center rounded-lg mb-6">
      <h1 class="text-2xl font-bold mb-2">ORI Dashboards</h1>
      <p class="text-sm">Interactive dashboards on research in the Netherlands</p>
    </header>

    <main>
      {% if apps %}
      {# <h2 class="text-xl font-bold text-center my-4">Apps</h2>
      <p class="text-center mb-4">Interactive applications in run mode - code is hidden for a clean user interface</p> #}
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {% for app in apps %}
        <!-- {{ app.display_name }} App -->
        <div class="bg-gray-50 border border-gray-200 rounded-lg overflow-hidden">
          <div class="bg-gray-100 p-3 font-semibold">{{ app.display_name }}</div>
          <div class="p-4">
            <a href="{{ app.html_path }}" class="inline-block bg-amber-500 hover:bg-amber-600 text-white py-1 px-3 rounded transition-colors"><img src="{{ app.image }}" alt="Dashboard image"></a>
          </div>
          <div class="p-3">
          {% for author in app.authors %}
            <div class="italic text-gray-500 text-sm">{{ author.name }}  <a href="{{ author.orcid }}"><img src="public/ORCID-iD_icon_unauth_vector.svg" alt="Orcid link" class="inline h-4"></a> <a href="{{ author.github }}"><img src="public/GitHub_Invertocat_Black.svg" alt="GitHub logo" class="inline h-4"></a></div>
          {% endfor%}
          </div>
        </div>
        {% endfor %}
      </div>
      {% endif %}
    </main>

    <footer class="mt-10 pt-6 border-t border-gray-200 text-center text-sm text-gray-600">
      <p class="mb-2">Built by the <a href="https://www.surf.nl/themas/open-science/open-research-information" target="_blank" class="text-blue-500 hover:underline">SURF Open Science Innovation team</a>.
      For feedback you can <a href="https://github.com/surf-ori/dashboards/issues" target="_blank" class="text-blue-500 hover:underline">raise an issue here</a>.
      Source code under <a href="https://github.com/surf-ori/dashboards" target="_blank" class="text-blue-500 hover:underline">https://github.com/surf-ori/dashboards</a>.
      This website is licenced as CC-BY. Data powering the dashboards may have a different licence.</p>
      <img src="https://www.surf.nl/themes/surf/logo.svg" alt="SURF logo" class="w-20 h-auto mx-auto mb-3">
    </footer>
  </div>
</body>
</html>